# ─────────────────────────────────────────────────────────────────────────────
# Variables d'environnement Kooach
# ─────────────────────────────────────────────────────────────────────────────
# Copier ce fichier en `.env.local` pour le dev, et configurer les mêmes
# variables sur Vercel (Settings → Environment Variables) pour la prod.

# ── Anthropic — moteur de génération ─────────────────────────────────────────
# Récupère ta clé sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase — base de données (profils, générations, events) ────────────────
# Project Settings → API → URL et "service_role" key (ne jamais exposer côté front)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe — paiements & abonnements ─────────────────────────────────────────
# Webhook secret : Dashboard → Developers → Webhooks → ton endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Optionnel mais recommandé : nécessaire pour générer des liens vers le
# Customer Portal (gérer/annuler son abonnement depuis /app/account).
STRIPE_SECRET_KEY=sk_live_...

# Optionnel : ID de configuration du Customer Portal Stripe (bpc_...).
# Si non défini, Stripe utilise la configuration par défaut.
STRIPE_PORTAL_CONFIG_ID=bpc_...

# ── Auth tokens (HMAC) ───────────────────────────────────────────────────────
# Chaîne aléatoire (32+ caractères). Génère avec : openssl rand -hex 32
# ⚠️  Si tu changes cette valeur, TOUS les tokens existants seront invalidés.
TOKEN_SECRET=

# ── Resend — envoi des emails d'accès ────────────────────────────────────────
# Récupère ta clé sur https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Cron Vercel — protège la route /api/cron/weekly-recap ────────────────────
# Vercel envoie automatiquement Authorization: Bearer ${CRON_SECRET} sur les
# requests cron. Génère avec : openssl rand -hex 32
# Configure-la aussi dans Vercel Dashboard → Settings → Environment Variables.
CRON_SECRET=

# ── Endpoints internes (founder-only, hook-generator, batch tools) ───────────
# Secret partagé pour protéger les endpoints /api/internal/* (pas exposés
# publiquement, utilisés depuis curl/scripts founder pour drafter des cold DMs).
# Génère avec : openssl rand -hex 32
INTERNAL_API_SECRET=

# Liste des emails autorisés à accéder aux routes /internal/* (founder/admin).
# Format comma-separated. Ex : "moi@example.com,cofounder@example.com"
FOUNDER_EMAILS=

# ── Supabase public (browser-side) ───────────────────────────────────────────
# La anon key est exposée au browser MAIS protégée par RLS côté DB.
# Voir supabase/migrations/20260505_rls_lockdown.sql avant de pousser en prod !
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── Sentry — error tracking (optionnel, fortement recommandé en prod) ────────
# Crée un projet sur https://sentry.io et copie le DSN.
# NEXT_PUBLIC_SENTRY_DSN est exposé au browser → volontaire (le DSN est public
# par design, il identifie juste ton projet Sentry).
# SENTRY_AUTH_TOKEN n'est utilisé qu'au build pour uploader les sourcemaps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
